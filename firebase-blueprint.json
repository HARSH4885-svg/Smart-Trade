{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and balance information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Display name" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "phoneNumber": { "type": "string", "description": "User phone number for OTP" },
        "balance": { "type": "number", "description": "Current wallet balance" },
        "joinDate": { "type": "string", "format": "date-time", "description": "Account creation date" },
        "fundTransactions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "amount": { "type": "number" },
              "type": { "type": "string", "enum": ["deposit", "withdraw"] },
              "category": { "type": "string" },
              "date": { "type": "string", "format": "date-time" },
              "balanceAfter": { "type": "number" }
            }
          }
        }
      },
      "required": ["uid", "balance"]
    },
    "Portfolio": {
      "title": "Portfolio",
      "description": "User's stock holdings and trading history",
      "type": "object",
      "properties": {
        "holdings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "stockId": { "type": "string" },
              "shares": { "type": "number" },
              "avgBuyPrice": { "type": "number" },
              "totalInvested": { "type": "number" }
            }
          }
        },
        "transactions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["BUY", "SELL"] },
              "stockId": { "type": "string" },
              "shares": { "type": "number" },
              "price": { "type": "number" },
              "total": { "type": "number" },
              "pnl": { "type": "number" },
              "timestamp": { "type": "string", "format": "date-time" },
              "balanceAfter": { "type": "number" }
            }
          }
        },
        "watchlist": {
          "type": "array",
          "items": { "type": "string" }
        },
        "limitOrders": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "stockId": { "type": "string" },
              "type": { "type": "string", "enum": ["BUY", "SELL"] },
              "targetPrice": { "type": "number" },
              "shares": { "type": "number" },
              "status": { "type": "string", "enum": ["PENDING", "EXECUTED", "CANCELLED"] },
              "createdAt": { "type": "string", "format": "date-time" },
              "executedAt": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "/portfolios/{userId}": {
      "schema": "Portfolio",
      "description": "User's trading portfolio and history"
    }
  }
}
